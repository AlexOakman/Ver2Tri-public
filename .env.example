# LLM Configuration
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=openai-compatible-model
LLM_API_KEY=your_api_key_here
LLM_TIMEOUT=900
LLM_MAX_TOKENS=50000
LLM_MAX_RETRIES=3
LLM_PROFILE_TRANSLATE=fast_no_think
LLM_PROFILE_PATTERN_GUARD=fast_no_think
LLM_PROFILE_API_VALIDATE=deep_think
LLM_PROFILE_TRINO_TEST=deep_think
LLM_PROFILE_COMPARE=deep_think
LLM_PROFILE_REPAIR=repair_think
# Optional per-profile model overrides
# LLM_PROFILE_FAST_NO_THINK_MODEL=
# LLM_PROFILE_DEEP_THINK_MODEL=
# LLM_PROFILE_REPAIR_THINK_MODEL=
# Deprecated compatibility fallback for repair_think when profile model is unset
# LLM_REPAIR_MODEL=
# Optional reasoning controls
# LLM_PROFILE_FAST_NO_THINK_REASONING_EFFORT=
# LLM_PROFILE_DEEP_THINK_REASONING_EFFORT=
# LLM_PROFILE_REPAIR_THINK_REASONING_EFFORT=
# Optional provider-specific JSON payload passed as extra_body on raw OpenAI repair calls
# LLM_PROFILE_FAST_NO_THINK_EXTRA_BODY_JSON={}
# LLM_PROFILE_DEEP_THINK_EXTRA_BODY_JSON={}
# LLM_PROFILE_REPAIR_THINK_EXTRA_BODY_JSON={}

# DSPy MIPROv2 Configuration
MIPRO_MAX_ITERATIONS=30
MIPRO_NUM_CANDIDATES=15

# Workflow Limits
TRANSLATION_RETRY_LIMIT=2
PATTERN_FIX_MAX_ITER=3

# Paths
WORKFLOW_BASE_PATH=./workflow
CHECKPOINT_PATH=./checkpoint/compiled_module.json
# Optional local override for private examples. Keep the directory ignored by Git.
# PRIVATE_GOLDEN_DATASET_PATH=./golden_dataset_private

# SQL Formatter (sqlfluff)
ENABLE_SQL_FORMATTER=true
SQL_FORMATTER_DIALECT=trino
# SQL_FORMATTER_RULES=L001,L002,L003,L004,L005  # Опционально: только эти правила
# SQL_FORMATTER_EXCLUDE_RULES=L034,L035        # Опционально: исключить правила

# Logging
LOG_LEVEL=INFO

# Optional SQL validation service
ENABLE_API_VALIDATION=false
API_VALIDATOR_URL=http://localhost:8080
API_VALIDATOR_TIMEOUT=60
API_VALIDATOR_POLL_INTERVAL=5

# Optional Trino runtime checks
ENABLE_TRINO_TEST=false
ENABLE_COMPARE=false
TRINO_HOST=localhost
TRINO_PORT=443
TRINO_USER=your_user
TRINO_CATALOG=demo_catalog
TRINO_SCHEMA=demo_schema
TRINO_PASSWORD=your_password_here
TRINO_SSL=true
TRINO_TEST_SCHEMA=runtime_schema
TRINO_TEST_MAX_FIX_ITERATIONS=3
TRINO_TEST_SAMPLE_LIMIT=1000
TRINO_COMPARE_FULL_LIMIT=100000000
